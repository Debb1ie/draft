renderGames(GAMES);

function showSection(s) {
  document.querySelectorAll('.nav-link').forEach(l=>l.classList.remove('active'));
  event.target.classList.add('active');
  if(s==='trending') renderGames(GAMES.filter(g=>g.hot).sort((a,b)=>b.players-a.players));
  else if(s==='new') renderGames(GAMES.filter(g=>g.new));
  else if(s==='multiplayer') renderGames(GAMES.filter(g=>g.players>10000));
  else renderGames(GAMES);
}
