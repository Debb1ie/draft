// MINI GAMES
function buildGame(g) {
  const wrap = document.getElementById('gameFrameWrap');
  const types = {
    puzzle: buildPuzzleGame,
    runner: buildRunnerGame,
    idle: buildIdleGame,
    default: buildDefaultGame,
  };
  const builder = types[g.gameType] || types.default;
  setTimeout(() => {
    wrap.innerHTML = '';
    const container = document.createElement('div');
    container.style.cssText = 'width:100%;height:500px;';
    wrap.appendChild(container);
    builder(container, g);
  }, 2000);
}

function buildDefaultGame(container, g) {
  const col = getColor(g.gameType);
  container.innerHTML = `
  <canvas id="miniGame" width="800" height="500" style="width:100%;height:100%;display:block;background:#000;"></canvas>`;
  const canvas = container.querySelector('#miniGame');
  const ctx = canvas.getContext('2d');
  let px=400,py=400,pvy=0,score=0,obstacles=[],particles=[];
  let running=true;
  const speed=4;
  function addObs(){obstacles.push({x:820,y:Math.random()*350+50,w:30,h:30});}
  function addParticle(x,y){for(let i=0;i<8;i++){particles.push({x,y,vx:(Math.random()-0.5)*6,vy:(Math.random()-0.5)*6,life:30,col});}}
  document.onkeydown=e=>{if(e.code==='Space'||e.code==='ArrowUp'){pvy=-14;e.preventDefault();}};
  canvas.onclick=()=>{pvy=-14;};
  let frame=0,obsTimer=0;
  function loop(){
    if(!running)return;
    ctx.fillStyle='#050510';ctx.fillRect(0,0,800,500);
    // ground
    ctx.fillStyle='#1a1a2e';ctx.fillRect(0,460,800,40);
    // stars
    ctx.fillStyle='rgba(255,255,255,0.3)';
    for(let i=0;i<50;i++){ctx.fillRect(((i*73+frame*0.5)%800),((i*37)%450),1,1);}
    // player
    pvy+=0.7;py+=pvy;
    if(py>430){py=430;pvy=0;}
    if(py<0){py=0;pvy=0;}
    ctx.font='2rem serif';ctx.fillText(g.emoji,px-20,py);
    // obstacles
    obsTimer++;if(obsTimer>80){addObs();obsTimer=0;}
    for(let i=obstacles.length-1;i>=0;i--){
      const o=obstacles[i];o.x-=speed+score/200;
      ctx.fillStyle=col;ctx.fillRect(o.x,o.y,o.w,o.h);
      if(o.x<-50){obstacles.splice(i,1);score+=10;}
      if(px+15>o.x&&px-15<o.x+o.w&&py+5>o.y&&py-25<o.y+o.h){
        addParticle(px,py);running=false;
        setTimeout(()=>{
          ctx.fillStyle='rgba(0,0,0,0.6)';ctx.fillRect(0,0,800,500);
          ctx.fillStyle='#fff';ctx.font='bold 2rem Exo 2,sans-serif';ctx.textAlign='center';
          ctx.fillText('Game Over!',400,220);
          ctx.font='1.2rem Exo 2,sans-serif';ctx.fillText('Score: '+score,400,260);
          ctx.font='1rem Exo 2,sans-serif';ctx.fillStyle=col;ctx.fillText('Click or Space to retry',400,300);
          canvas.onclick=()=>{obstacles=[];score=0;py=400;pvy=0;running=true;canvas.onclick=()=>{pvy=-14;};loop();};
        },500);
      }
    }
    // particles
    for(let i=particles.length-1;i>=0;i--){
      const p=particles[i];p.x+=p.vx;p.y+=p.vy;p.life--;
      ctx.globalAlpha=p.life/30;ctx.fillStyle=p.col;ctx.fillRect(p.x,p.y,4,4);
      if(p.life<=0)particles.splice(i,1);
    }
    ctx.globalAlpha=1;
    // score
    ctx.fillStyle='#fff';ctx.font='bold 1rem Space Mono,monospace';ctx.textAlign='left';
    ctx.fillText('SCORE: '+score,20,30);
    ctx.fillStyle=col;ctx.fillText('JUMP: Click or Space',20,50);
    frame++;requestAnimationFrame(loop);
  }
  loop();
}

function buildPuzzleGame(container, g) {
  const col = getColor(g.gameType);
  container.innerHTML = `
  <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:500px;gap:1rem;background:#05050f;">
    <div style="color:#fff;font-weight:700;font-size:1.1rem;">Color Memory Challenge</div>
    <div id="pzGrid" style="display:grid;grid-template-columns:repeat(4,70px);gap:8px;"></div>
    <div style="color:${col};font-size:0.9rem;" id="pzMsg">Watch the sequence!</div>
    <div style="color:#fff;font-size:1rem;" id="pzScore">Level: 1</div>
  </div>`;
  const colors=['#7c3aed','#06b6d4','#ef4444','#10b981','#f59e0b','#ec4899','#8b5cf6','#14b8a6'];
  let seq=[],playerSeq=[],level=1,showing=false;
  const grid=container.querySelector('#pzGrid');
  const msg=container.querySelector('#pzMsg');
  const sc=container.querySelector('#pzScore');
  for(let i=0;i<8;i++){
    const btn=document.createElement('button');
    btn.style.cssText=`width:70px;height:70px;border-radius:12px;background:${colors[i]};border:none;cursor:pointer;opacity:0.5;transition:opacity 0.15s;font-size:1.5rem;`;
    btn.onclick=()=>{if(showing)return;btn.style.opacity='1';setTimeout(()=>btn.style.opacity='0.5',200);playerSeq.push(i);check(i);};
    grid.appendChild(btn);
  }
  function check(idx){
    const btns=[...grid.children];
    if(playerSeq[playerSeq.length-1]!==seq[playerSeq.length-1]){msg.textContent='Wrong! Starting over...';msg.style.color='#ef4444';setTimeout(()=>{seq=[];playerSeq=[];level=1;sc.textContent='Level: 1';nextRound();},1200);return;}
    if(playerSeq.length===seq.length){level++;sc.textContent='Level: '+level;msg.style.color=col;msg.textContent='Correct! Watch next...';playerSeq=[];setTimeout(nextRound,800);}
  }
  function nextRound(){
    seq.push(Math.floor(Math.random()*8));showing=true;msg.textContent='Watch the sequence!';msg.style.color='#fff';
    const btns=[...grid.children];let i=0;
    const interval=setInterval(()=>{
      if(i>0)btns[seq[i-1]].style.opacity='0.5';
      if(i<seq.length){btns[seq[i]].style.opacity='1';i++;}
      else{clearInterval(interval);showing=false;msg.textContent='Your turn! Repeat the sequence';msg.style.color=col;}
    },700);
  }
  nextRound();
}

function buildIdleGame(container, g) {
  const col = getColor(g.gameType);
  let coins=0,cps=0,clickVal=1,upgrades=[
    {name:'⛏️ Basic Miner',cost:50,cps:0.5,owned:0},
    {name:'🤖 Robot Worker',cost:300,cps:3,owned:0},
    {name:'🏭 Factory',cost:2000,cps:15,owned:0},
    {name:'🚀 Space Miner',cost:15000,cps:100,owned:0},
  ];
  function render(){
    container.innerHTML=`
    <div style="display:flex;height:500px;background:#05050f;color:#fff;font-family:Exo 2,sans-serif;">
      <div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1rem;border-right:1px solid rgba(255,255,255,0.1);">
        <div style="font-size:0.85rem;color:${col};">COINS PER SECOND: ${cps.toFixed(1)}</div>
        <div style="font-size:2.5rem;font-weight:900;">${Math.floor(coins).toLocaleString()}</div>
        <div style="font-size:0.9rem;color:#888;">coins</div>
        <button id="bigClick" style="width:140px;height:140px;border-radius:50%;background:linear-gradient(135deg,${col},#06b6d4);border:none;cursor:pointer;font-size:3.5rem;transition:transform 0.1s;box-shadow:0 0 30px ${col}44;">
          ${g.emoji}
        </button>
        <div style="font-size:0.8rem;color:#888;">+${clickVal} per click</div>
      </div>
      <div style="width:260px;padding:1rem;overflow-y:auto;display:flex;flex-direction:column;gap:8px;">
        <div style="font-size:0.8rem;color:#888;margin-bottom:4px;text-transform:uppercase;">Upgrades</div>
        ${upgrades.map((u,i)=>`
          <button onclick="buyUpgrade(${i})" style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:10px;padding:10px;text-align:left;cursor:pointer;color:#fff;font-family:inherit;transition:background 0.2s;" onmouseover="this.style.background='rgba(124,58,237,0.2)'" onmouseout="this.style.background='rgba(255,255,255,0.05)'">
            <div style="font-weight:600;font-size:0.88rem;">${u.name} <span style="color:${col}">(${u.owned})</span></div>
            <div style="font-size:0.75rem;color:#888;">+${u.cps} CPS · 💰 ${u.cost.toLocaleString()}</div>
          </button>`).join('')}
      </div>
    </div>`;
    document.getElementById('bigClick').onmousedown=e=>{e.currentTarget.style.transform='scale(0.93)';};
    document.getElementById('bigClick').onmouseup=e=>{e.currentTarget.style.transform='scale(1)';coins+=clickVal;render();};
    window.buyUpgrade=(i)=>{if(coins>=upgrades[i].cost){coins-=upgrades[i].cost;upgrades[i].owned++;cps+=upgrades[i].cps;upgrades[i].cost=Math.floor(upgrades[i].cost*1.5);if(upgrades[i].owned%5===0)clickVal++;render();}};
  }
  render();
  setInterval(()=>{coins+=cps/10;const el=container.querySelector('div[style*="2.5rem"]');if(el)el.textContent=Math.floor(coins).toLocaleString();},100);
}

function openGame(g) {
  const modal = document.getElementById('modalBackdrop');
  document.getElementById('modalEmoji').textContent = g.emoji;
  document.getElementById('modalTitle').textContent = g.name;
  const stars = '⭐'.repeat(Math.floor(g.rating)) + (g.rating % 1 >= 0.5 ? '½' : '');
  document.getElementById('modalRating').innerHTML = `<span class="star">${'★'.repeat(Math.floor(g.rating))}${'☆'.repeat(5-Math.floor(g.rating))}</span>`;
  document.getElementById('modalPlayers').textContent = `${g.players.toLocaleString()} playing`;
  document.getElementById('gameFrameWrap').innerHTML = `
    <div class="game-frame-placeholder">
      <div class="big-emoji">${g.emoji}</div>
      <div style="font-weight:700;font-size:1.2rem;color:var(--text);">${g.name}</div>
      <div style="font-size:0.85rem;color:var(--muted);">Loading game engine...</div>
      <div class="loading-bar"><div class="loading-bar-fill"></div></div>
    </div>`;
  modal.classList.add('open');
  document.body.style.overflow = 'hidden';
  buildGame(g);
}

function closeModal() {
  document.getElementById('modalBackdrop').classList.remove('open');
  document.body.style.overflow = '';
  document.getElementById('gameFrameWrap').innerHTML = '';
  document.onkeydown = null;
}

function closeModalOutside(e) {
  if (e.target === document.getElementById('modalBackdrop')) closeModal();
}

document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

