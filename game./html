document.getElementById('ticker').innerHTML = tickerData + tickerData;

// COUNTER ANIMATION
function countUp(el, target, suffix='', dur=2000) {
  let start=0, step=target/60;
  const isK = target > 999;
  const timer = setInterval(()=>{
    start+=step;
    if(start>=target){start=target;clearInterval(timer);}
    el.textContent = isK ? (start/1000).toFixed(0)+'K' : Math.floor(start) + suffix;
  }, dur/60);
}
countUp(document.getElementById('cntr-games'), GAMES.length);
countUp(document.getElementById('cntr-players'), 182400);

