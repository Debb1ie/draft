      <div class="featured-actions">
        <button class="btn-primary" style="padding:10px 28px;font-size:0.95rem;" onclick="event.stopPropagation();openGame(featuredGame)">▶ Play Free Now</button>
        <button class="btn-secondary">ℹ More Info</button>
      </div>
    </div>
  </div>

  <!-- CATEGORIES -->
  <div class="section-header">
    <span class="section-title">Browse by Category</span>
  </div>
  <div class="cat-scroll" style="margin-bottom:2rem;">
    <button class="cat-chip active" onclick="filterByCategory('all', this)">🎮 All Games</button>
    <button class="cat-chip" onclick="filterByCategory('action', this)">⚔️ Action</button>
    <button class="cat-chip" onclick="filterByCategory('puzzle', this)">🧩 Puzzle</button>
    <button class="cat-chip" onclick="filterByCategory('racing', this)">🏎️ Racing</button>
    <button class="cat-chip" onclick="filterByCategory('strategy', this)">♟️ Strategy</button>
    <button class="cat-chip" onclick="filterByCategory('adventure', this)">🗺️ Adventure</button>
    <button class="cat-chip" onclick="filterByCategory('sports', this)">⚽ Sports</button>
    <button class="cat-chip" onclick="filterByCategory('shooter', this)">🔫 Shooter</button>
    <button class="cat-chip" onclick="filterByCategory('rpg', this)">🧙 RPG</button>
    <button class="cat-chip" onclick="filterByCategory('survival', this)">🌲 Survival</button>
    <button class="cat-chip" onclick="filterByCategory('idle', this)">💰 Idle</button>
  </div>

  <!-- HOT NOW -->
  <div class="section-header">
    <span class="section-title">🔥 Hot Now</span>
    <span class="section-badge badge-hot">Live</span>
    <button class="see-all">See All →</button>
  </div>
  <div class="game-grid" id="gameGrid"></div>

</div>

<!-- MODAL -->
<div class="modal-backdrop" id="modalBackdrop" onclick="closeModalOutside(event)">
  <div class="modal" id="gameModal">
    <div class="modal-header">
      <span id="modalEmoji" style="font-size:1.5rem;"></span>
      <span class="modal-title" id="modalTitle"></span>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-body">
      <div class="game-frame-wrap" id="gameFrameWrap">
        <div class="game-frame-placeholder" id="gamePlaceholder">
          <div class="big-emoji" id="placeholderEmoji"></div>
          <div style="font-weight:700;font-size:1.1rem;color:var(--text);" id="placeholderTitle"></div>
          <div style="font-size:0.85rem;">Loading game engine...</div>
          <div class="loading-bar"><div class="loading-bar-fill" id="loadBar"></div></div>
          <div id="gameContainer" style="width:100%;"></div>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <div class="game-rating" id="modalRating"></div>
      <span style="font-size:0.82rem;color:var(--muted);" id="modalPlayers"></span>
      <div class="modal-free-badge">✓ 100% Free</div>
    </div>
  </div>
</div>

<footer>
  <strong>GameVerse</strong> &nbsp;·&nbsp; 2024 &nbsp;·&nbsp; All games are free to play &nbsp;·&nbsp; No account required for most games
</footer>

